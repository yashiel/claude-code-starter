# ============================================
# Environment Variables
# ============================================
# Copy to .env.local and fill in values
# NEVER commit .env or .env.local to version control
# Validate all vars at startup via lib/env.ts
# ============================================

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Appwrite — Public (safe to expose)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT=

# Appwrite — Server only (NEVER prefix with NEXT_PUBLIC_)
NEXT_APPWRITE_KEY=

# ---- PAYMENT PROVIDERS ----

# Stripe — Server only
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe — Client safe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# PayPal — Server only
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_API_URL=https://api-m.sandbox.paypal.com
# PayPal — Client safe (for JS SDK buttons)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# TNG Digital — ALL server only (NEVER prefix with NEXT_PUBLIC_)
TNG_CLIENT_ID=                   # Client-Id header for API requests
TNG_PARTNER_ID=                  # partnerId in request bodies
TNG_PRIVATE_KEY=                 # RSA private key for request signing (PEM format or base64)
TNG_PUBLIC_KEY=                  # TNG's public key for response verification
TNG_API_URL=https://open-api-tng.tngdigital.com.my
TNG_APP_ID=                      # Mini Program app ID

# External Services (add as needed)
# RESEND_API_KEY=
